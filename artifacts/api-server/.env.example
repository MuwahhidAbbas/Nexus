# Copy this file to .env and fill in your values

# PostgreSQL connection string from Supabase
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Random secret for sessions (generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-random-secret

# Port the API server listens on
PORT=8080

# Comma-separated list of allowed frontend origins (your Netlify URL)
# Leave empty to allow all origins (OK for testing)
ALLOWED_ORIGINS=https://your-site.netlify.app
